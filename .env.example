# ── 複製此檔案為 .env 並填入實際值 ──

# Supabase PostgreSQL 連線字串
# 格式: postgresql+asyncpg://[user]:[password]@[host]:[port]/[dbname]
# Supabase 連線字串可在 Project Settings > Database > Connection string 找到
# 注意：使用 Session mode (port 5432)，Transaction mode (port 6543) 不支援 asyncpg
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# 爬蟲間隔（秒），Render Free tier 建議不要低於 60
SCRAPE_INTERVAL_SECONDS=60

# PTT 看板名稱
PTT_BOARD=Stock

# 每次爬取頁數（頁數越多，準確度越高，但也越慢）
MAX_PAGES=3
